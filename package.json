{
  "name": "hive",
  "version": "1.0.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "react-native-worklets": "0.5.1",
      "react-native-reanimated>react-native-worklets": "0.5.1"
    }
  },
  "scripts": {
    "dev:mobile": "pnpm --filter @hive/mobile start",
    "dev:backend": "pnpm --filter @hive/backend dev",
    "build:backend": "pnpm --filter @hive/backend build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
